---
import BaseLayout from "../layouts/BaseLayout.astro";

const metadata = {
  title: "Tools — Tijdvermogen",
  description:
    "Financiële calculators om scenario's te simuleren: wanneer passief inkomen kan starten en welke inlegmix nodig is.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="mb-3 text-sm uppercase tracking-[0.18em] text-primary">Tools</p>
    <h1 class="font-serif text-4xl font-semibold sm:text-5xl">Financiële routekaart calculators</h1>
    <p class="mt-4 max-w-3xl text-muted-foreground">
      Zes kernscenario's zijn geïntegreerd: van <strong>passief inkomen plannen</strong> en
      <strong>inlegmix kiezen</strong> tot <strong>inflatie-impact</strong> en
      <strong>tijd terugkopen via beleggen</strong>.
    </p>
  </section>

  <section class="mx-auto max-w-7xl space-y-10 px-4 pb-20 sm:px-6 lg:px-8">
    <article class="rounded-3xl border border-border bg-card p-6 md:p-8">
      <h2 class="font-serif text-3xl font-semibold">1) Passief inkomen simulator</h2>
      <p class="mt-2 text-muted-foreground">Zoekt automatisch de vroegste haalbare startdatum binnen de opgegeven maximale uitkeringsduur.</p>

      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <label class="text-sm">Huidig kapitaal (€)<input id="tv-startKapitaal" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="25000" /></label>
        <label class="text-sm">Maandelijkse inleg (€)<input id="tv-maandInleg" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="400" /></label>
        <label class="text-sm">Doel passief inkomen/maand vandaag (€)<input id="tv-doelUitkeringVandaag" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="500" /></label>
        <label class="text-sm">Max duur uitkering (jaren)<input id="tv-uitkeringsJaren" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="30" /></label>
        <label class="text-sm">Rendement p.j. (%)<input id="tv-rendement" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" step="0.1" value="5" /></label>
        <label class="text-sm">Inflatie (%)<input id="tv-inflatie" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" step="0.1" value="2" /></label>
        <label class="text-sm">Minimaal eindkapitaal (€)<input id="tv-minEindKapitaal" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="0" /></label>
        <label class="flex items-center gap-2 text-sm"><input id="tv-indexeer" type="checkbox" /> Indexeer uitkering met inflatie</label>
      </div>

      <div class="mt-4 flex flex-wrap gap-3">
        <button id="tv-btnBereken" class="rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white">Simuleer</button>
        <button id="tv-btnReset" class="rounded-full border border-border px-5 py-2 text-sm font-semibold">Reset</button>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-4">
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Start uitkering</p><p id="tv-kpiStart" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Geïnvesteerd kapitaal</p><p id="tv-kpiGeinvesteerd" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Kapitaal bij start</p><p id="tv-kpiKapitaalStart" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Totaal uitgekeerd</p><p id="tv-kpiTotaalUitgekeerd" class="font-mono">—</p></div>
      </div>

      <div class="mt-6 overflow-x-auto rounded-2xl border border-border">
        <table class="min-w-full text-sm">
          <thead class="bg-muted text-left"><tr><th class="px-3 py-2">Scenario</th><th class="px-3 py-2">Rendement</th><th class="px-3 py-2">Start mogelijk?</th><th class="px-3 py-2">Start na</th><th class="px-3 py-2">Startbedrag</th><th class="px-3 py-2">Eindkapitaal</th></tr></thead>
          <tbody id="tv-scenarioBody"><tr><td class="px-3 py-2 text-muted-foreground" colspan="6">Klik op simuleer.</td></tr></tbody>
        </table>
      </div>
      <p id="tv-status" class="mt-3 text-sm text-muted-foreground">Status: nog niet uitgevoerd.</p>
    </article>

    <article class="rounded-3xl border border-border bg-card p-6 md:p-8">
      <h2 class="font-serif text-3xl font-semibold">2) Inleg-verdeler</h2>
      <p class="mt-2 text-muted-foreground">Jij kiest wanneer de uitkering start. De tool toont combinaties tussen startbedrag en maandelijkse inleg.</p>

      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <label class="text-sm">Start uitkering na (jaren)<input id="mix-startNaJaren" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="10" /></label>
        <label class="text-sm">Duur uitkering (jaren)<input id="mix-duurJaren" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="30" /></label>
        <label class="text-sm">Doel passief inkomen/maand vandaag (€)<input id="mix-doelVandaag" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="500" /></label>
        <label class="text-sm">Minimaal eindkapitaal (€)<input id="mix-minEind" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="0" /></label>
        <label class="text-sm">Rendement p.j. (%)<input id="mix-rendement" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" step="0.1" value="5" /></label>
        <label class="text-sm">Inflatie (%)<input id="mix-inflatie" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" step="0.1" value="2" /></label>
        <label class="flex items-center gap-2 text-sm"><input id="mix-indexeer" type="checkbox" /> Indexeer uitkering met inflatie</label>
        <label class="text-sm">Aantal opties<input id="mix-stappen" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="11" min="5" /></label>
      </div>

      <div class="mt-4 flex flex-wrap gap-3">
        <button id="mix-btn" class="rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white">Simuleer</button>
        <button id="mix-btnReset" class="rounded-full border border-border px-5 py-2 text-sm font-semibold">Reset</button>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Benodigd kapitaal op startdatum</p><p id="mix-kpiKreq" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Max startbedrag (0 inleg)</p><p id="mix-kpiLumpOnly" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Max maandinleg (0 startbedrag)</p><p id="mix-kpiContribOnly" class="font-mono">—</p></div>
      </div>

      <div class="mt-6 overflow-x-auto rounded-2xl border border-border">
        <table class="min-w-full text-sm">
          <thead class="bg-muted text-left"><tr><th class="px-3 py-2">% startbedrag</th><th class="px-3 py-2">Startbedrag vandaag</th><th class="px-3 py-2">Maandelijkse inleg</th><th class="px-3 py-2">Totaal ingelegd t/m start</th></tr></thead>
          <tbody id="mix-tbody"><tr><td class="px-3 py-2 text-muted-foreground" colspan="4">Klik op simuleer.</td></tr></tbody>
        </table>
      </div>
      <p id="mix-status" class="mt-3 text-sm text-muted-foreground">Status: nog niet uitgevoerd.</p>
    </article>

    <article class="rounded-3xl border border-border bg-card p-6 md:p-8">
      <h2 class="font-serif text-3xl font-semibold">3) Inflatie realiteit</h2>
      <p class="mt-2 text-muted-foreground">Toont het verschil tussen nominale bedragen en reële koopkracht over een gekozen tijdshorizon.</p>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <label class="text-sm">Bedrag vandaag (€)<input id="inf-bedrag" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="2000" /></label>
        <label class="text-sm">Inflatie (%)<input id="inf-inflatie" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" step="0.1" value="2" /></label>
        <label class="text-sm">Tijdshorizon (jaren)<input id="inf-jaren" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="20" min="1" /></label>
      </div>

      <div class="mt-4 flex flex-wrap gap-3">
        <button id="inf-btn" class="rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white">Simuleer</button>
        <button id="inf-reset" class="rounded-full border border-border px-5 py-2 text-sm font-semibold">Reset</button>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Nominaal nodig in de toekomst</p><p id="inf-kpi-nominaal" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Reële waarde van vast nominaal bedrag op horizon</p><p id="inf-kpi-reeel" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Cumulatieve inflatie</p><p id="inf-kpi-cum" class="font-mono">—</p></div>
      </div>

      <div class="mt-6 relative">
        <canvas id="inf-chart" class="h-72 w-full rounded-2xl border border-border bg-background"></canvas>
        <div id="inf-tooltip" class="pointer-events-none absolute hidden rounded-xl border border-border bg-background/95 px-3 py-2 text-xs shadow-lg"></div>
      </div>
      <p id="inf-status" class="mt-3 text-sm text-muted-foreground">Status: nog niet uitgevoerd.</p>
    </article>

    <article class="rounded-3xl border border-border bg-card p-6 md:p-8">
      <h2 class="font-serif text-3xl font-semibold">4) Werkuren-impact door inflatie</h2>
      <p class="mt-2 text-muted-foreground">Bereken hoeveel extra werkuren nodig zijn op basis van aparte looninflatie en asset-inflatie.</p>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <label class="text-sm">Kost van doel (bv. huis) vandaag (€)<input id="work-kost" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="300000" /></label>
        <label class="text-sm">Netto maandloon (€)<input id="work-loon" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="2500" /></label>
        <label class="text-sm">Werkuren per week<input id="work-uren-week" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="38" /></label>
        <label class="text-sm">Inflatie loon (%)<input id="work-loon-inflatie" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" step="0.1" value="2" /></label>
        <label class="text-sm">Inflatie asset (%)<input id="work-asset-inflatie" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" step="0.1" value="4" /></label>
        <label class="text-sm">Tijdshorizon (jaren)<input id="work-jaren" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="15" min="1" /></label>
      </div>

      <div class="mt-4 flex flex-wrap gap-3">
        <button id="work-btn" class="rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white">Simuleer</button>
        <button id="work-reset" class="rounded-full border border-border px-5 py-2 text-sm font-semibold">Reset</button>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-4">
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Kost op horizon</p><p id="work-kpi-kost" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Werkuren op horizon</p><p id="work-kpi-future" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Extra t.o.v. nu</p><p id="work-kpi-extra" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Equivalent in tijd (extra + totaal)</p><p id="work-kpi-equivalent" class="font-mono">—</p></div>
      </div>

      <div class="mt-6 relative">
        <canvas id="work-chart" class="h-72 w-full rounded-2xl border border-border bg-background"></canvas>
        <div id="work-tooltip" class="pointer-events-none absolute hidden rounded-xl border border-border bg-background/95 px-3 py-2 text-xs shadow-lg"></div>
      </div>
      <p id="work-status" class="mt-3 text-sm text-muted-foreground">Status: nog niet uitgevoerd.</p>
    </article>

    <article class="rounded-3xl border border-border bg-card p-6 md:p-8">
      <h2 class="font-serif text-3xl font-semibold">5) Tijd afbouwen richting pensioen</h2>
      <p class="mt-2 text-muted-foreground">Toont wanneer je je werkregime kan terugschroeven naar 80/60/50/40/20/0% met belegd kapitaal, binnen je resterende loopbaan.</p>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <label class="text-sm">Netto maandwedde (€)<input id="ret-loon" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="2500" /></label>
        <label class="text-sm">Werkuren per week<input id="ret-uren-week" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="38" /></label>
        <label class="text-sm">Te beleggen deel van maandloon (%)<input id="ret-invest-pct" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="15" /></label>
        <label class="text-sm">Eenmalig startbedrag (€)<input id="ret-start" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="10000" /></label>
        <label class="text-sm">Beoogd rendement p.j. (%)<input id="ret-rend" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" step="0.1" value="5" /></label>
        <label class="text-sm">Inflatie (%)<input id="ret-infl" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" step="0.1" value="2" /></label>
        <label class="text-sm">Jaren tot officieel pensioen<input id="ret-jaren-pensioen" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="25" min="1" /></label>
        <label class="flex items-center gap-2 text-sm"><input id="ret-indexeer" type="checkbox" checked /> Indexeer inkomenskloof met inflatie</label>
      </div>

      <div class="mt-4 flex flex-wrap gap-3">
        <button id="ret-btn" class="rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white">Simuleer</button>
        <button id="ret-reset" class="rounded-full border border-border px-5 py-2 text-sm font-semibold">Reset</button>
      </div>

      <div class="mt-6 overflow-x-auto rounded-2xl border border-border">
        <table class="min-w-full text-sm">
          <thead class="bg-muted text-left"><tr><th class="px-3 py-2">Doelregime</th><th class="px-3 py-2">Maandelijkse inkomenskloof</th><th class="px-3 py-2">Vroegste haalbaar binnen horizon</th><th class="px-3 py-2">Benodigd kapitaal (duurzaam)</th></tr></thead>
          <tbody id="ret-tbody"><tr><td class="px-3 py-2 text-muted-foreground" colspan="4">Klik op simuleer.</td></tr></tbody>
        </table>
      </div>

      <p class="mt-5 text-sm font-semibold text-foreground">Impact van verschillende belegpercentages (lijnengrafiek)</p>
      <div class="mt-2 relative">
        <canvas id="ret-sens-chart" class="h-72 w-full rounded-2xl border border-border bg-background"></canvas>
        <div id="ret-sens-tooltip" class="pointer-events-none absolute hidden rounded-xl border border-border bg-background/95 px-3 py-2 text-xs shadow-lg"></div>
      </div>

      <p id="ret-status" class="mt-3 text-sm text-muted-foreground">Status: nog niet uitgevoerd.</p>
    </article>

    <article class="rounded-3xl border border-border bg-card p-6 md:p-8">
      <h2 class="font-serif text-3xl font-semibold">6) Beleggen = tijd inkopen</h2>
      <p class="mt-2 text-muted-foreground">Drukt je belegd kapitaal uit in werkuren, maanden en jaren om te tonen hoeveel tijd je kan terugkopen.</p>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <label class="text-sm">Netto maandwedde (€)<input id="time-loon" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="2500" /></label>
        <label class="text-sm">Werkuren per week<input id="time-uren-week" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="38" /></label>
        <label class="text-sm">Te beleggen deel van maandloon (%)<input id="time-invest-pct" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="15" /></label>
        <label class="text-sm">Eenmalig startbedrag (€)<input id="time-start" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="10000" /></label>
        <label class="text-sm">Beoogd rendement p.j. (%)<input id="time-rend" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" step="0.1" value="5" /></label>
        <label class="text-sm">Inflatie (%)<input id="time-infl" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" step="0.1" value="2" /></label>
        <label class="text-sm">Tijdshorizon (jaren)<input id="time-jaren" class="mt-1 w-full rounded-xl border border-border bg-background px-3 py-2" type="number" value="20" min="1" /></label>
        <label class="flex items-center gap-2 text-sm"><input id="time-indexeer" type="checkbox" checked /> Toon koopkracht in euro van vandaag</label>
      </div>

      <div class="mt-4 flex flex-wrap gap-3">
        <button id="time-btn" class="rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white">Simuleer</button>
        <button id="time-reset" class="rounded-full border border-border px-5 py-2 text-sm font-semibold">Reset</button>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-4">
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Kapitaal op horizon</p><p id="time-kpi-cap" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Equivalent in werkuren</p><p id="time-kpi-hours" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Equivalent in werkmaanden</p><p id="time-kpi-months" class="font-mono">—</p></div>
        <div class="rounded-2xl border border-border p-4"><p class="text-xs text-muted-foreground">Equivalent in werkjaren</p><p id="time-kpi-years" class="font-mono">—</p></div>
      </div>

      <p id="time-status" class="mt-3 text-sm text-muted-foreground">Status: nog niet uitgevoerd.</p>
    </article>

  </section>

  <script>
    const el = (id) => document.getElementById(id);
    const formatEUR = (n) => new Intl.NumberFormat('nl-BE', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n);
    const monthlyRate = (annualPct) => Math.pow(1 + annualPct / 100, 1 / 12) - 1;
    const monthlyInflationRate = (inflPct) => Math.pow(1 + inflPct / 100, 1 / 12) - 1;
    const uplift = (todayAmount, startMonth, indexToInflation, inflationPct) => indexToInflation ? todayAmount * Math.pow(1 + monthlyInflationRate(inflationPct), startMonth) : todayAmount;

    function simulate({ initialCapital, monthlyContribution, annualReturnPct, startWithdrawMonth, withdrawalPerMonthToday, withdrawalYears, indexToInflation, inflationPct, minEndCapital }) {
      const rM = monthlyRate(annualReturnPct);
      const inflY = inflationPct / 100;
      const monthsWithdraw = Math.max(1, Math.round(withdrawalYears * 12));
      const totalMonths = startWithdrawMonth + monthsWithdraw;
      let cap = Math.max(0, initialCapital);
      let w = Math.max(0, uplift(withdrawalPerMonthToday, startWithdrawMonth, indexToInflation, inflationPct));
      let totalPaid = 0;
      let minCapSeen = cap;

      for (let m = 0; m <= totalMonths; m++) {
        minCapSeen = Math.min(minCapSeen, cap);
        cap *= 1 + rM;
        if (m < startWithdrawMonth) {
          cap += monthlyContribution;
        } else if (m < totalMonths) {
          cap -= w;
          totalPaid += w;
          if (indexToInflation && (m - startWithdrawMonth + 1) % 12 === 0) w *= 1 + inflY;
        }
      }

      return {
        ok: minCapSeen >= 0 && cap >= Math.max(0, minEndCapital),
        endCap: cap,
        totalPaid,
        startMonthlyPayout: uplift(withdrawalPerMonthToday, startWithdrawMonth, indexToInflation, inflationPct),
      };
    }

    function findEarliestStart(params, maxYears) {
      const maxMonths = Math.max(1, Math.round(maxYears * 12));
      for (let start = 0; start <= maxMonths; start++) {
        const res = simulate({ ...params, startWithdrawMonth: start });
        if (res.ok) return { startMonth: start, res };
      }
      return null;
    }

    function runMain() {
      const inp = {
        initialCapital: Number(el('tv-startKapitaal').value || 0),
        monthlyContribution: Number(el('tv-maandInleg').value || 0),
        withdrawalPerMonthToday: Number(el('tv-doelUitkeringVandaag').value || 0),
        withdrawalYears: Number(el('tv-uitkeringsJaren').value || 1),
        annualReturnPct: Number(el('tv-rendement').value || 0),
        inflationPct: Number(el('tv-inflatie').value || 0),
        minEndCapital: Number(el('tv-minEindKapitaal').value || 0),
        indexToInflation: el('tv-indexeer').checked,
      };

      const scenarios = [{ name: 'Pessimistisch', r: inp.annualReturnPct - 2.5 }, { name: 'Basis', r: inp.annualReturnPct }, { name: 'Optimistisch', r: inp.annualReturnPct + 2.5 }];
      const foundBase = findEarliestStart({ ...inp, annualReturnPct: scenarios[1].r }, inp.withdrawalYears);

      const tb = el('tv-scenarioBody');
      tb.innerHTML = '';
      scenarios.forEach((s) => {
        const f = findEarliestStart({ ...inp, annualReturnPct: s.r }, inp.withdrawalYears);
        const tr = document.createElement('tr');
        tr.innerHTML = `<td class="px-3 py-2">${s.name}</td><td class="px-3 py-2">${s.r.toFixed(1)}%</td><td class="px-3 py-2">${f ? 'Ja' : 'Nee'}</td><td class="px-3 py-2">${f ? (f.startMonth / 12).toFixed(1) + ' jr' : '—'}</td><td class="px-3 py-2">${f ? formatEUR(f.res.startMonthlyPayout) : '—'}</td><td class="px-3 py-2">${f ? formatEUR(f.res.endCap) : '—'}</td>`;
        tb.appendChild(tr);
      });

      if (!foundBase) {
        el('tv-status').textContent = 'Status: geen haalbare start binnen de gekozen termijn.';
        ['tv-kpiStart', 'tv-kpiGeinvesteerd', 'tv-kpiKapitaalStart', 'tv-kpiTotaalUitgekeerd'].forEach((id) => (el(id).textContent = '—'));
        return;
      }

      let capAtStart = inp.initialCapital;
      const rM = monthlyRate(inp.annualReturnPct);
      for (let m = 0; m < foundBase.startMonth; m++) capAtStart = capAtStart * (1 + rM) + inp.monthlyContribution;

      el('tv-kpiStart').textContent = `${(foundBase.startMonth / 12).toFixed(1)} jaar`;
      el('tv-kpiGeinvesteerd').textContent = formatEUR(inp.initialCapital + inp.monthlyContribution * foundBase.startMonth);
      el('tv-kpiKapitaalStart').textContent = formatEUR(capAtStart);
      el('tv-kpiTotaalUitgekeerd').textContent = formatEUR(foundBase.res.totalPaid);
      el('tv-status').textContent = `Status: haalbaar, start-uitkering ${formatEUR(foundBase.res.startMonthlyPayout)}/mnd op startdatum.`;
    }

    function simulateWithdrawalOnly({ capitalAtStart, annualReturnPct, startMonthlyPayout, withdrawalYears, indexDuringWithdrawal, inflationPct, minEndCapital }) {
      const rM = monthlyRate(annualReturnPct);
      const inflY = inflationPct / 100;
      const monthsWithdraw = Math.max(1, Math.round(withdrawalYears * 12));
      let cap = Math.max(0, capitalAtStart);
      let w = Math.max(0, startMonthlyPayout);
      let minCapSeen = cap;
      for (let m = 0; m < monthsWithdraw; m++) {
        cap *= 1 + rM;
        cap -= w;
        minCapSeen = Math.min(minCapSeen, cap);
        if (indexDuringWithdrawal && (m + 1) % 12 === 0) w *= 1 + inflY;
      }
      return minCapSeen >= 0 && cap >= Math.max(0, minEndCapital);
    }

    function findRequiredCapitalAtStart(params) {
      let low = 0;
      let high = Math.max(1000, params.minEndCapital || 0);
      while (!simulateWithdrawalOnly({ ...params, capitalAtStart: high })) {
        high *= 2;
        if (high > 2e9) break;
      }
      for (let i = 0; i < 70; i++) {
        const mid = (low + high) / 2;
        if (simulateWithdrawalOnly({ ...params, capitalAtStart: mid })) high = mid;
        else low = mid;
      }
      return high;
    }

    function runMix() {
      const startMonth = Math.round(Number(el('mix-startNaJaren').value || 0) * 12);
      const withdrawalYears = Number(el('mix-duurJaren').value || 1);
      const todayPayout = Number(el('mix-doelVandaag').value || 0);
      const minEndCapital = Number(el('mix-minEind').value || 0);
      const annualReturnPct = Number(el('mix-rendement').value || 0);
      const inflationPct = Number(el('mix-inflatie').value || 0);
      const indexToInflation = el('mix-indexeer').checked;
      const steps = Math.max(5, Number(el('mix-stappen').value || 11));

      const startPayout = uplift(todayPayout, startMonth, indexToInflation, inflationPct);
      const Kreq = findRequiredCapitalAtStart({ annualReturnPct, startMonthlyPayout: startPayout, withdrawalYears, indexDuringWithdrawal: indexToInflation, inflationPct, minEndCapital });
      const rM = monthlyRate(annualReturnPct);
      const grow = Math.pow(1 + rM, startMonth);
      const A = Math.abs(rM) < 1e-12 ? startMonth : (Math.pow(1 + rM, startMonth) - 1) / rM;
      const lumpOnly = startMonth === 0 ? Kreq : Kreq / grow;
      const contribOnly = startMonth === 0 ? 0 : Kreq / A;

      el('mix-kpiKreq').textContent = formatEUR(Kreq);
      el('mix-kpiLumpOnly').textContent = formatEUR(lumpOnly);
      el('mix-kpiContribOnly').textContent = `${formatEUR(contribOnly)}/mnd`;

      const tb = el('mix-tbody');
      tb.innerHTML = '';
      for (let i = 0; i < steps; i++) {
        const p = steps === 1 ? 100 : (i / (steps - 1)) * 100;
        const S0 = (p / 100) * lumpOnly;
        const needed = Kreq - S0 * grow;
        const c = startMonth === 0 ? 0 : Math.max(0, needed / A);
        const totalIn = S0 + c * startMonth;
        const tr = document.createElement('tr');
        tr.innerHTML = `<td class="px-3 py-2">${p.toFixed(0)}%</td><td class="px-3 py-2">${formatEUR(S0)}</td><td class="px-3 py-2">${formatEUR(c)}/mnd</td><td class="px-3 py-2">${formatEUR(totalIn)}</td>`;
        tb.appendChild(tr);
      }
      el('mix-status').textContent = `Status: berekening uitgevoerd bij rendement ${annualReturnPct.toFixed(1)}%.`;
    }


    function drawLineChart({ canvasId, tooltipId, labels, datasets, formatValue }) {
      const canvas = el(canvasId);
      const tooltip = el(tooltipId);
      if (!canvas || !tooltip || labels.length < 2) return;

      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      canvas.width = Math.floor(w * dpr);
      canvas.height = Math.floor(h * dpr);
      ctx.scale(dpr, dpr);

      const all = datasets.flatMap((d) => d.values);
      const minY = Math.min(...all);
      let maxY = Math.max(...all);
      if (minY === maxY) maxY = minY + 1;

      const pad = { top: 18, right: 20, bottom: 36, left: 58 };
      const plotW = w - pad.left - pad.right;
      const plotH = h - pad.top - pad.bottom;
      const xTo = (i) => pad.left + (i / (labels.length - 1)) * plotW;
      const yTo = (v) => pad.top + (1 - (v - minY) / (maxY - minY)) * plotH;

      ctx.clearRect(0, 0, w, h);
      ctx.strokeStyle = 'rgba(148,163,184,.35)';
      ctx.lineWidth = 1;

      for (let i = 0; i <= 4; i++) {
        const y = pad.top + (i / 4) * plotH;
        ctx.beginPath();
        ctx.moveTo(pad.left, y);
        ctx.lineTo(w - pad.right, y);
        ctx.stroke();
      }

      ctx.fillStyle = 'rgba(148,163,184,.8)';
      ctx.font = '12px system-ui';
      for (let i = 0; i <= 4; i++) {
        const v = maxY - (i / 4) * (maxY - minY);
        ctx.fillText(formatValue(v), 6, pad.top + (i / 4) * plotH + 4);
      }

      const tickStep = Math.max(1, Math.floor(labels.length / 8));
      for (let i = 0; i < labels.length; i += tickStep) {
        const x = xTo(i);
        ctx.fillText(String(labels[i]), x - 8, h - 12);
      }

      datasets.forEach((ds) => {
        ctx.strokeStyle = ds.color;
        ctx.lineWidth = 2;
        ctx.beginPath();
        ds.values.forEach((v, i) => {
          const x = xTo(i);
          const y = yTo(v);
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        });
        ctx.stroke();
      });

      canvas.onmousemove = (evt) => {
        const rect = canvas.getBoundingClientRect();
        const x = evt.clientX - rect.left;
        if (x < pad.left || x > w - pad.right) {
          tooltip.classList.add('hidden');
          return;
        }
        const idx = Math.max(0, Math.min(labels.length - 1, Math.round(((x - pad.left) / plotW) * (labels.length - 1))));
        const rows = datasets.map((d) => `<div><span style="color:${d.color}">●</span> ${d.label}: <strong>${formatValue(d.values[idx])}</strong></div>`).join('');
        tooltip.innerHTML = `<div><strong>Jaar ${labels[idx]}</strong></div>${rows}`;
        tooltip.classList.remove('hidden');
        tooltip.style.left = `${Math.min(w - 180, x + 12)}px`;
        tooltip.style.top = `${Math.max(8, evt.clientY - rect.top - 10)}px`;
      };
      canvas.onmouseleave = () => tooltip.classList.add('hidden');
    }

    function runInflationReality() {
      const bedrag = Number(el('inf-bedrag').value || 0);
      const infl = Number(el('inf-inflatie').value || 0) / 100;
      const jaren = Math.max(1, Number(el('inf-jaren').value || 1));

      const nominalNeeded = bedrag * Math.pow(1 + infl, jaren);
      const cumulativeInfl = (Math.pow(1 + infl, jaren) - 1) * 100;
      const realValueAtHorizon = bedrag / Math.pow(1 + infl, jaren);

      el('inf-kpi-nominaal').textContent = formatEUR(nominalNeeded);
      el('inf-kpi-reeel').textContent = formatEUR(realValueAtHorizon);
      el('inf-kpi-cum').textContent = `${cumulativeInfl.toFixed(1)}%`;
      el('inf-status').textContent = `Status: bij ${((infl || 0) * 100).toFixed(1)}% inflatie heb je over ${jaren} jaar ${formatEUR(nominalNeeded)} nodig; een vast nominaal bedrag van ${formatEUR(bedrag)} behoudt dan ${formatEUR(realValueAtHorizon)} koopkracht.`;

      const labels = Array.from({ length: jaren + 1 }, (_, i) => i);
      const fixedNominalSeries = labels.map(() => bedrag);
      const nominalFutureSeries = labels.map((yr) => bedrag * Math.pow(1 + infl, yr));
      const realSeries = labels.map((yr) => bedrag / Math.pow(1 + infl, yr));
      drawLineChart({
        canvasId: 'inf-chart',
        tooltipId: 'inf-tooltip',
        labels,
        datasets: [
          { label: 'Vast nominaal bedrag', values: fixedNominalSeries, color: '#3b82f6' },
          { label: 'Nominaal bedrag in toekomst', values: nominalFutureSeries, color: '#f97316' },
          { label: 'Reële koopkracht in toekomst', values: realSeries, color: '#22c55e' },
        ],
        formatValue: (v) => formatEUR(v),
      });
    }

    function runWorkHoursImpact() {
      const kostVandaag = Number(el('work-kost').value || 0);
      const nettoLoon = Number(el('work-loon').value || 0);
      const urenPerWeek = Number(el('work-uren-week').value || 1);
      const loonInfl = Number(el('work-loon-inflatie').value || 0) / 100;
      const assetInfl = Number(el('work-asset-inflatie').value || 0) / 100;
      const jaren = Math.max(1, Number(el('work-jaren').value || 1));

      const uurloonNu = (nettoLoon * 12) / Math.max(1, urenPerWeek * 52);
      const futureCost = kostVandaag * Math.pow(1 + assetInfl, jaren);
      const futureHourlyWage = uurloonNu * Math.pow(1 + loonInfl, jaren);
      const hoursNow = kostVandaag / uurloonNu;
      const hoursFuture = futureCost / Math.max(0.0001, futureHourlyWage);
      const extraHours = hoursFuture - hoursNow;
      const monthlyHours = urenPerWeek * 52 / 12;
      const monthsExtra = extraHours / monthlyHours;
      const yearsExtra = extraHours / (urenPerWeek * 52);
      const monthsTotal = hoursFuture / monthlyHours;
      const yearsTotal = hoursFuture / (urenPerWeek * 52);

      el('work-kpi-kost').textContent = formatEUR(futureCost);
      el('work-kpi-future').textContent = `${hoursFuture.toFixed(0)} u`;
      el('work-kpi-extra').textContent = `${extraHours.toFixed(0)} u`;
      el('work-kpi-equivalent').textContent = `extra: ${monthsExtra.toFixed(1)} mnd · ${yearsExtra.toFixed(1)} jr | totaal: ${monthsTotal.toFixed(1)} mnd · ${yearsTotal.toFixed(1)} jr`;
      el('work-status').textContent = `Status: extra impact = ${extraHours.toFixed(0)} u (${monthsExtra.toFixed(1)} maanden / ${yearsExtra.toFixed(1)} jaar). Totaal op horizon: ${hoursFuture.toFixed(0)} u.`;

      const labels = Array.from({ length: jaren + 1 }, (_, i) => i);
      const hoursSeries = labels.map((yr) => {
        const c = kostVandaag * Math.pow(1 + assetInfl, yr);
        const w = uurloonNu * Math.pow(1 + loonInfl, yr);
        return c / Math.max(0.0001, w);
      });
      const baselineSeries = labels.map(() => hoursNow);
      const extraSeries = labels.map((_, i) => Math.max(0, hoursSeries[i] - hoursNow));
      drawLineChart({
        canvasId: 'work-chart',
        tooltipId: 'work-tooltip',
        labels,
        datasets: [
          { label: 'Werkuren nodig (totaal)', values: hoursSeries, color: '#f97316' },
          { label: 'Werkuren nu (baseline)', values: baselineSeries, color: '#8b5cf6' },
          { label: 'Extra werkuren', values: extraSeries, color: '#ef4444' },
        ],
        formatValue: (v) => `${Math.round(v).toLocaleString('nl-BE')} u`,
      });
    }

    function futureValueFromPlan({ startCapital, monthlyContribution, annualReturnPct, years }) {
      const months = Math.max(1, Math.round(years * 12));
      const rM = monthlyRate(annualReturnPct);
      let capital = Math.max(0, startCapital);
      for (let m = 0; m < months; m++) {
        capital = capital * (1 + rM) + Math.max(0, monthlyContribution);
      }
      return capital;
    }

    function yearsToReachCapital({ targetCapital, startCapital, monthlyContribution, annualReturnPct, maxYears }) {
      if (targetCapital <= Math.max(0, startCapital)) return 0;
      const months = Math.max(1, Math.round(maxYears * 12));
      const rM = monthlyRate(annualReturnPct);
      let capital = Math.max(0, startCapital);
      for (let m = 1; m <= months; m++) {
        capital = capital * (1 + rM) + Math.max(0, monthlyContribution);
        if (capital >= targetCapital) return m / 12;
      }
      return null;
    }

    function runRetirementScaleDown() {
      const nettoLoon = Number(el('ret-loon').value || 0);
      const urenPerWeek = Number(el('ret-uren-week').value || 1);
      const investPct = Number(el('ret-invest-pct').value || 0) / 100;
      const startCapital = Number(el('ret-start').value || 0);
      const annualReturnPct = Number(el('ret-rend').value || 0);
      const inflationPct = Number(el('ret-infl').value || 0);
      const yearsToPension = Math.max(1, Number(el('ret-jaren-pensioen').value || 1));
      const indexToInflation = el('ret-indexeer').checked;

      const monthlyInvest = Math.max(0, nettoLoon * investPct);
      const nominalMonthlyRate = monthlyRate(annualReturnPct);
      const realMonthlyRate = (1 + nominalMonthlyRate) / (1 + monthlyInflationRate(inflationPct)) - 1;
      const sustainableMonthlyRate = indexToInflation ? realMonthlyRate : nominalMonthlyRate;
      const targets = [0.8, 0.6, 0.5, 0.4, 0.2, 0.0];
      const tbody = el('ret-tbody');
      tbody.innerHTML = '';

      targets.forEach((ratio) => {
        const incomeGap = nettoLoon * (1 - ratio);
        const requiredCapital = sustainableMonthlyRate > 0 ? incomeGap / sustainableMonthlyRate : Number.POSITIVE_INFINITY;
        const yearsNeeded = Number.isFinite(requiredCapital)
          ? yearsToReachCapital({
              targetCapital: requiredCapital,
              startCapital,
              monthlyContribution: monthlyInvest,
              annualReturnPct,
              maxYears: yearsToPension,
            })
          : null;
        const tr = document.createElement('tr');
        tr.innerHTML = `<td class="px-3 py-2">${Math.round(ratio * 100)}%</td><td class="px-3 py-2">${formatEUR(incomeGap)}/mnd</td><td class="px-3 py-2">${yearsNeeded === null ? 'Niet haalbaar' : `${yearsNeeded.toFixed(1)} jaar`}</td><td class="px-3 py-2">${Number.isFinite(requiredCapital) ? formatEUR(requiredCapital) : 'Niet duurzaam (reëel rendement ≤ 0%)'}</td>`;
        tbody.appendChild(tr);
      });

      const sensitivityPcts = Array.from(new Set([
        Math.max(1, Math.round(investPct * 100 - 5)),
        Math.max(1, Math.round(investPct * 100)),
        Math.max(1, Math.round(investPct * 100 + 5)),
        Math.max(1, Math.round(investPct * 100 + 10)),
      ])).sort((a, b) => a - b);
      const regimeLabels = [80, 60, 50, 40, 20, 0];
      const colors = ['#3b82f6', '#ef4444', '#14b8a6', '#8b5cf6', '#f97316', '#22c55e'];
      const datasets = sensitivityPcts.map((pct, idx) => {
        const monthly = nettoLoon * (pct / 100);
        const values = targets.map((ratio) => {
          const required = sustainableMonthlyRate > 0 ? (nettoLoon * (1 - ratio)) / sustainableMonthlyRate : Number.POSITIVE_INFINITY;
          const y = Number.isFinite(required)
            ? yearsToReachCapital({
                targetCapital: required,
                startCapital,
                monthlyContribution: monthly,
                annualReturnPct,
                maxYears: yearsToPension,
              })
            : null;
          return y === null ? yearsToPension : y;
        });
        return {
          label: `${pct}% beleggen`,
          values,
          color: colors[idx % colors.length],
        };
      });

      drawLineChart({
        canvasId: 'ret-sens-chart',
        tooltipId: 'ret-sens-tooltip',
        labels: regimeLabels,
        datasets,
        formatValue: (v) => `${v.toFixed(1)} jr`,
      });

      const lifeMode = indexToInflation ? 'geïndexeerde inkomenskloof' : 'niet-geïndexeerde inkomenskloof';
      const sustainability = sustainableMonthlyRate > 0
        ? `Duurzaamheid is berekend als eeuwigdurende opname met ${(sustainableMonthlyRate * 100).toFixed(3)}% maandrendement.`
        : 'Niet duurzaam bij deze combinatie van rendement en inflatie (reëel rendement ≤ 0%).';
      const urenPerMaand = urenPerWeek * 52 / 12;
      el('ret-status').textContent = `Status: ${formatEUR(monthlyInvest)}/mnd beleggen (${(investPct * 100).toFixed(1)}%), ${lifeMode}, ${urenPerMaand.toFixed(0)} u/maand huidig tempo. ${sustainability}`;
    }

    function runBuyTime() {
      const nettoLoon = Number(el('time-loon').value || 0);
      const urenPerWeek = Number(el('time-uren-week').value || 1);
      const investPct = Number(el('time-invest-pct').value || 0) / 100;
      const startCapital = Number(el('time-start').value || 0);
      const annualReturnPct = Number(el('time-rend').value || 0);
      const inflationPct = Number(el('time-infl').value || 0);
      const jaren = Math.max(1, Number(el('time-jaren').value || 1));
      const showRealValue = el('time-indexeer').checked;

      const monthlyInvest = Math.max(0, nettoLoon * investPct);
      const nominalCap = futureValueFromPlan({ startCapital, monthlyContribution: monthlyInvest, annualReturnPct, years: jaren });
      const deflator = Math.pow(1 + inflationPct / 100, jaren);
      const cap = showRealValue ? nominalCap / Math.max(0.0001, deflator) : nominalCap;
      const uurloonNu = (nettoLoon * 12) / Math.max(1, urenPerWeek * 52);
      const hoursEquivalent = cap / Math.max(0.0001, uurloonNu);
      const monthsEquivalent = hoursEquivalent / (urenPerWeek * 52 / 12);
      const yearsEquivalent = hoursEquivalent / (urenPerWeek * 52);

      el('time-kpi-cap').textContent = formatEUR(cap);
      el('time-kpi-hours').textContent = `${Math.round(hoursEquivalent).toLocaleString('nl-BE')} u`;
      el('time-kpi-months').textContent = `${monthsEquivalent.toFixed(1)} mnd`;
      el('time-kpi-years').textContent = `${yearsEquivalent.toFixed(1)} jr`;
      el('time-status').textContent = `Status: ${showRealValue ? 'koopkracht in euro van vandaag' : 'nominale waarde op horizon'} ≈ ${Math.round(hoursEquivalent).toLocaleString('nl-BE')} werkuren (${monthsEquivalent.toFixed(1)} maanden / ${yearsEquivalent.toFixed(1)} jaar).`;
    }

    el('tv-btnBereken')?.addEventListener('click', runMain);
    el('mix-btn')?.addEventListener('click', runMix);

    el('inf-btn')?.addEventListener('click', runInflationReality);
    el('work-btn')?.addEventListener('click', runWorkHoursImpact);
    el('ret-btn')?.addEventListener('click', runRetirementScaleDown);
    el('time-btn')?.addEventListener('click', runBuyTime);

    el('tv-btnReset')?.addEventListener('click', () => {
      el('tv-startKapitaal').value = 25000;
      el('tv-maandInleg').value = 400;
      el('tv-doelUitkeringVandaag').value = 500;
      el('tv-uitkeringsJaren').value = 30;
      el('tv-rendement').value = 5;
      el('tv-inflatie').value = 2;
      el('tv-minEindKapitaal').value = 0;
      el('tv-indexeer').checked = false;
      runMain();
    });

    el('inf-reset')?.addEventListener('click', () => {
      el('inf-bedrag').value = 2000;
      el('inf-inflatie').value = 2;
      el('inf-jaren').value = 20;
      runInflationReality();
    });
    el('work-reset')?.addEventListener('click', () => {
      el('work-kost').value = 300000;
      el('work-loon').value = 2500;
      el('work-uren-week').value = 38;
      el('work-loon-inflatie').value = 2;
      el('work-asset-inflatie').value = 4;
      el('work-jaren').value = 15;
      runWorkHoursImpact();
    });

    el('ret-reset')?.addEventListener('click', () => {
      el('ret-loon').value = 2500;
      el('ret-uren-week').value = 38;
      el('ret-invest-pct').value = 15;
      el('ret-start').value = 10000;
      el('ret-rend').value = 5;
      el('ret-infl').value = 2;
      el('ret-indexeer').checked = true;
      el('ret-jaren-pensioen').value = 25;
      runRetirementScaleDown();
    });

    el('time-reset')?.addEventListener('click', () => {
      el('time-loon').value = 2500;
      el('time-uren-week').value = 38;
      el('time-invest-pct').value = 15;
      el('time-start').value = 10000;
      el('time-rend').value = 5;
      el('time-infl').value = 2;
      el('time-indexeer').checked = true;
      el('time-jaren').value = 20;
      runBuyTime();
    });

    el('mix-btnReset')?.addEventListener('click', () => {
      el('mix-startNaJaren').value = 10;
      el('mix-duurJaren').value = 30;
      el('mix-doelVandaag').value = 500;
      el('mix-minEind').value = 0;
      el('mix-rendement').value = 5;
      el('mix-inflatie').value = 2;
      el('mix-indexeer').checked = false;
      el('mix-stappen').value = 11;
      runMix();
    });

    runMain();
    runMix();
    runInflationReality();
    runWorkHoursImpact();
    runRetirementScaleDown();
    runBuyTime();
  </script>
</BaseLayout>
