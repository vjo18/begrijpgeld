---
import BaseLayout from "../layouts/BaseLayout.astro";

const metadata = {
  title: "Over Tijdvermogen",
  description:
    "Het merkverhaal van Tijdvermogen: waarom geld opgeslagen levenstijd is en hoe dat je keuzes verandert.",
};

const taglines = [
  "Geld is levenstijd.",
  "Bescherm je tijdvermogen.",
  "Omdat geld eigenlijk tijd is.",
  "Je geld. Je tijd. Je leven.",
  "Financiële keuzes zijn levenskeuzes.",
  "Wie geld begrijpt, beschermt zijn tijd.",
];
---

<BaseLayout {metadata}>
  <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6 lg:px-8">
    <p class="mb-4 text-sm uppercase tracking-[0.2em] text-primary">Brand story</p>
    <h1 class="font-serif text-4xl font-semibold sm:text-5xl">Over Tijdvermogen</h1>
    <p class="mt-6 text-lg text-muted-foreground">
      De meeste mensen denken over geld in cijfers. In inkomsten, uitgaven en rendement.
      Tijdvermogen vertrekt vanuit een andere kijk: geld is opgeslagen levenstijd.
    </p>
  </section>

  <section class="mx-auto grid max-w-7xl gap-6 px-4 pb-8 sm:px-6 lg:grid-cols-2 lg:px-8">
    <article class="rounded-3xl border border-border p-8">
      <h2 class="font-serif text-3xl font-semibold">Waarom dit ertoe doet</h2>
      <p class="mt-4 text-muted-foreground">
        Elke euro staat voor uren die we gewerkt, geleerd, gezorgd of gecreëerd hebben.
        Toch geven we vaak geld uit zonder stil te staan bij de tijd erachter.
      </p>
      <p class="mt-4 text-muted-foreground">
        Daardoor wordt koopkrachtverlies iets abstracts en lijken financiële keuzes los te
        staan van het leven dat we willen leiden.
      </p>
    </article>

    <article class="rounded-3xl border border-border bg-muted p-8">
      <h2 class="font-serif text-3xl font-semibold">Onze missie</h2>
      <p class="mt-4 text-muted-foreground">
        Mensen helpen hun tijd te beschermen door hun relatie met geld te begrijpen. Niet
        met snelle tips of hype, maar met inzicht, rust en reflectie.
      </p>
      <p class="mt-4 font-medium">
        Want wie geld begrijpt, beschermt zijn tijd. En wie zijn tijd beschermt,
        beschermt zijn leven.
      </p>
    </article>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h2 class="font-serif text-3xl font-semibold">Elevator pitch</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-3">
      <article class="rounded-2xl border border-border p-6">
        <h3 class="font-semibold">30 seconden</h3>
        <p class="mt-3 text-sm text-muted-foreground">
          Tijdvermogen helpt mensen begrijpen dat geld opgeslagen levenstijd is. Via
          educatie, psychologie en filosofische inzichten leren ze bewuster omgaan met
          geld, koopkracht beschermen en keuzes maken die hun vrijheid ondersteunen.
        </p>
      </article>
      <article class="rounded-2xl border border-border p-6">
        <h3 class="font-semibold">10 seconden</h3>
        <p class="mt-3 text-sm text-muted-foreground">
          Ik help mensen begrijpen dat geld levenstijd is, zodat ze bewuster omgaan met
          geld en hun koopkracht beschermen.
        </p>
      </article>
      <article class="rounded-2xl border border-border p-6">
        <h3 class="font-semibold">Website / bio</h3>
        <p class="mt-3 text-sm text-muted-foreground">
          Tijdvermogen maakt geld menselijker door te vertrekken vanuit tijd. Dat creëert
          betere keuzes, minder stress en meer vrijheid op lange termijn.
        </p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
    <h2 class="font-serif text-3xl font-semibold">Taglines</h2>
    <div class="mt-6 grid gap-3 md:grid-cols-2 lg:grid-cols-3">
      {
        taglines.map((line) => (
          <p class="rounded-2xl border border-border bg-card px-4 py-3 text-sm font-medium">
            {line}
          </p>
        ))
      }
    </div>
  </section>
</BaseLayout>
